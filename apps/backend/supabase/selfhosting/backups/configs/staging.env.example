ENV="staging"

# Storage buckets (rclone remotes)
SOURCE_BUCKET="remote_name:bucket_name"
RESTORE_BUCKET="remote_name:bucket_name"

# Backup destination
BACKUP_ROOT="remote_name:bucket_name/folder_name"

# SSH connection to Supabase server
SSH_KEY="ssh_key_path"
SERVER_IP="server_ip"
SSH_PORT="ssh_port"
SSH_USER="ssh_username"

# Database connection (via SSH tunnel)
DB_NAME="postgres"
DB_USER="postgres"
DB_PASSWORD="db_password"
LOCAL_DB_PORT="15432"
DB_CONTAINER="supabase-db"

# Encryption
GPG_RECIPIENT="GPG_Email"

# Retention policy
RETENTION_DAYS="30"

# rclone performance tuning
TRANSFERS="16"
CHECKERS="32"

