# Supabase selfhosting environment example
# Copy to staging/.env or production/.env and fill values.

# Core secrets (use generate-keys.js for these)
POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
SECRET_KEY_BASE=
VAULT_ENC_KEY=
PG_META_CRYPTO_KEY=
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# Hosts / ports
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
POOLER_PROXY_PORT_TRANSACTION=6543

# Public URLs / domains
SUPABASE_PUBLIC_URL=https://your-domain.example
API_EXTERNAL_URL=https://your-domain.example
SITE_URL=https://your-frontend.example
ADDITIONAL_REDIRECT_URLS=

# Auth and behavior toggles
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
FUNCTIONS_VERIFY_JWT=true
JWT_EXPIRY=3600

# PostgREST
PGRST_DB_SCHEMAS=public

# SMTP / Mailer
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
GOTRUE_MAILER_SECURE_EMAIL_CHANGE_ENABLED=true
# Change these to the URLs of your actual email templates:
MAILER_TEMPLATES_INVITE_URL=https://example.com/invite.html
MAILER_TEMPLATES_CONFIRMATION_URL=https://example.com/confirmation.html
MAILER_TEMPLATES_RECOVERY_URL=https://example.com/recovery.html
MAILER_TEMPLATES_EMAIL_CHANGE_URL=https://example.com/email_change.html

MAILER_SUBJECTS_INVITE="Sie wurden eingeladen"
MAILER_SUBJECTS_CONFIRMATION="Bestätigen Sie Ihre E-Mail-Adresse"
MAILER_SUBJECTS_RECOVERY="Passwort zurücksetzen"
MAILER_SUBJECTS_MAGIC_LINK="Einmaliger Anmeldelink für Ihr Konto"
MAILER_SUBJECTS_EMAIL_CHANGE="Bestätigen Sie Ihre E-Mail-Adresse"
GOTRUE_MAILER_EXTERNAL_HOSTS=baergpt-supabase-url.com,kong
# Storage / S3
GLOBAL_S3_BUCKET=
GLOBAL_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Analytics / Logflare
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=

# Supavisor (pooler)
POOLER_TENANT_ID=local
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=20

# Studio defaults
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
