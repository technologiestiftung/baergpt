{
	"name": "baergpt-backend",
	"version": "0.0.0",
	"scripts": {
		"build": "npm run build:deps && npm run build:tsc && npm run build:puppeteer && npm run build:sourcemaps",
		"build:deps": "npm ci",
		"build:tsc": "tsc",
		"build:puppeteer": "(npx puppeteer browsers list | grep -q 'chrome' || npx puppeteer browsers install chrome)",
		"build:sourcemaps": "sentry-cli sourcemaps inject --org $SENTRY_ORG --project $SENTRY_PROJECT ./dist && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT ./dist",
		"start": "tsc && node --env-file-if-exists=.env dist/src/index.js",
		"dev": "tsx --watch ./src/index.ts",
		"test": "vitest run src/integration",
		"test:watch": "vitest watch src/integration",
		"lint:check": "ESLINT_USE_FLAT_CONFIG=true eslint \"src/**/*\"",
		"lint:write": "ESLINT_USE_FLAT_CONFIG=true eslint \"src/**/*\" --fix",
		"lint:db": "./supabase/lint-database.sh",
		"prettier:check": "prettier --check src supabase",
		"prettier:write": "prettier --write src supabase",
		"db:typegen": "supabase gen types --lang typescript --local > src/types/auto-generated-database-types.ts && npm run prettier:write && npm run lint:fix",
		"db:localseed": "tsx ./supabase/local-seed.ts"
	},
	"dependencies": {
		"@ai-sdk/openai": "2.0.23",
		"@ai-sdk/openai-compatible": "1.0.13",
		"@ai-sdk/azure": "2.0.23",
		"@ai-sdk/mistral": "2.0.12",
		"@dqbd/tiktoken": "1.0.17",
		"@hono/node-server": "1.14.4",
		"@mistralai/mistralai": "1.9.18",
		"@opendocsg/pdf2md": "0.2.1",
		"@opentelemetry/auto-instrumentations-node": "0.57.0",
		"@opentelemetry/sdk-node": "0.57.2",
		"@quail-ai/azure-ai-provider": "1.0.5",
		"@sentry/cli": "2.52.0",
		"@sentry/node": "10.5.0",
		"@sentry/profiling-node": "10.5.0",
		"@supabase/supabase-js": "2.45.6",
		"ai": "5.0.10",
		"dotenv": "16.4.7",
		"hono": "4.8.10",
		"jsonwebtoken": "9.0.2",
		"langfuse-vercel": "3.37.0",
		"mammoth": "1.9.1",
		"pdf-lib": "1.17.1",
		"puppeteer": "24.11.2",
		"word-extractor": "1.0.4",
		"xlsx": "npm:@e965/xlsx@0.20.3",
		"zod": "4.1.11"
	},
	"devDependencies": {
		"@repo/typescript-config": "file:../../libs/typescript-config",
		"@types/node": "22.5.0",
		"@types/pdf-parse": "1.1.4",
		"@types/supertest": "6.0.3",
		"date-fns": "4.1.0",
		"globals": "15.15.0",
		"nodemon": "3.1.4",
		"supertest": "7.1.0",
		"tsx": "4.19.3",
		"vitest": "3.1.1"
	},
	"overrides": {
		"zod": "4.1.11"
	}
}
