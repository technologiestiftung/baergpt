{
	"name": "baergpt-backend",
	"version": "0.0.0",
	"scripts": {
		"check-types": "tsc --noEmit",
		"build": "tsc",
		"build:prod": "npm run build && npm run build:sourcemaps",
		"build:sourcemaps": "sentry-cli sourcemaps inject --org $SENTRY_ORG --project $SENTRY_PROJECT ./dist && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT ./dist",
		"start": "tsc && node --env-file-if-exists=.env dist/src/index.js",
		"dev": "tsx --watch ./src/index.ts",
		"test": "vitest run src",
		"test:watch": "vitest watch src",
		"lint:check": "ESLINT_USE_FLAT_CONFIG=true eslint \"src/**/*\"",
		"lint:write": "ESLINT_USE_FLAT_CONFIG=true eslint \"src/**/*\" --fix",
		"lint:db": "./supabase/lint-database.sh",
		"prettier:check": "prettier --check src supabase",
		"prettier:write": "prettier --write src supabase",
		"db:reset": "supabase db reset && npm run db:typegen && npm run db:localseed",
		"db:typegen": "supabase gen types --lang typescript --local > ../../libs/db-schema/index.ts && prettier --write ../../libs/db-schema/index.ts && ESLINT_USE_FLAT_CONFIG=true eslint --fix ../../libs/db-schema/index.ts",
		"db:localseed": "tsx ./supabase/local-seed.ts"
	},
	"dependencies": {
		"@ai-sdk/mistral": "2.0.17",
		"@dqbd/tiktoken": "1.0.17",
		"@hono/node-server": "1.14.4",
		"@langfuse/client": "4.2.0",
		"@langfuse/core": "4.2.0",
		"@langfuse/otel": "4.2.0",
		"@langfuse/tracing": "4.2.0",
		"@mistralai/mistralai": "1.9.18",
		"@opendocsg/pdf2md": "0.2.1",
		"@opentelemetry/auto-instrumentations-node": "0.65.0",
		"@opentelemetry/sdk-node": "0.206.0",
		"@opentelemetry/sdk-trace-node": "2.1.0",
		"@repo/db-schema": "file:../../libs/db-schema",
		"@sentry/node": "10.20.0",
		"@sentry/profiling-node": "10.20.0",
		"@supabase/supabase-js": "2.45.6",
		"ai": "5.0.60",
		"dotenv": "16.4.7",
		"hono": "4.8.10",
		"jsonwebtoken": "9.0.2",
		"mammoth": "1.9.1",
		"pdf-parse": "2.4.5",
		"throttled-queue": "3.0.0",
		"word-extractor": "1.0.4",
		"xlsx": "npm:@e965/xlsx@0.20.3",
		"zod": "4.1.11"
	},
	"devDependencies": {
		"@repo/typescript-config": "file:../../libs/typescript-config",
		"@types/node": "22.5.0",
		"@types/pdf-parse": "1.1.4",
		"@types/supertest": "6.0.3",
		"date-fns": "4.1.0",
		"globals": "15.15.0",
		"nodemon": "3.1.4",
		"supertest": "7.1.0",
		"tsx": "4.19.3",
		"typescript": "5.8.3",
		"vitest": "3.1.1"
	},
	"overrides": {
		"zod": "4.1.11"
	}
}
