{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["dist/**"]
    },
    "baergpt-backend#build": {
      "env": ["SENTRY_ORG", "SENTRY_PROJECT", "SENTRY_AUTH_TOKEN", "SENTRY_DSN"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint:check": {},
    "lint:write": {},
    "prettier:check": {},
    "prettier:write": {},
    "test": {},
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
        "dependsOn": ["^build"]
    }
  },
  "globalDependencies": [".env", "tsconfig.json"]
}