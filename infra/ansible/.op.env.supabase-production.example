# 1Password secret references for the supabase production server
ANSIBLE_HOST=op://vault/production-server/hostname
ANSIBLE_USER=op://vault/production-server/username
ANSIBLE_PORT=op://vault/production-server/port
STACKIT_PROJECT_ID=op://vault/production-stackit/project-id
STACKIT_SERVICE_ACCOUNT_JSON=op://vault/production-stackit/service-account-json
ENV_FILE_REF=vault/production-supabase/env-file
DOMAIN=example.berlin
LETSENCRYPT_EMAIL=example@example.berlin
ANSIBLE_SSH_KEY=op://vault/production-server/ssh-private-key-path
MIGRATIONS_SSH_PUBLIC_KEY=op://vault/production-migrations/public-key
